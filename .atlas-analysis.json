  "keyFeatures": [
    "POSIX-compliant shell interpreter",
    "Sandboxed in-process execution",
    "Virtual filesystem (InMemoryFs, OverlayFs, MountableFs)",
    "Resource limits (commands, loops, function depth)",
    "100+ built-in commands",
    "Network allowlist for HTTP access",
    "Async-first with tokio",
    "Custom builtin support",
    "Experimental Git support (virtual operations)",
    "Experimental Python support (embedded interpreter)",
    "Tool trait for LLM integration",
    "Python bindings with LangChain/PydanticAI support",
    "CLI with MCP server mode",
    "Scripted tool orchestration"
